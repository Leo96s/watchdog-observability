NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=watchdog
DB_USER=watchdog
DB_PASSWORD=changeme

# Required to authorize write requests (POST/PATCH/DELETE) on /api/services.
# Send it back as the X-API-Key header.
ADMIN_API_KEY=changeme

# Comma-separated list of origins allowed by CORS.
FRONTEND_ORIGIN=http://localhost:5173

# EmailJS is the email alert provider actually used by alert.service.js.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
