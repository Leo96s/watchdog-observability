# Used by docker-compose.yml

DB_NAME=watchdog
DB_USER=watchdog
DB_PASSWORD=changeme

POSTGRES_PORT=5432
BACKEND_PORT=3000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Required to authorize write requests (POST/PATCH/DELETE) on /api/services.
ADMIN_API_KEY=changeme

# Origin(s) allowed by backend CORS, comma-separated.
FRONTEND_ORIGIN=http://localhost:80

# Base URL the frontend uses to reach the backend API.
VITE_API_URL=http://localhost:3000

# EmailJS is the email alert provider actually used by alert.service.js.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
